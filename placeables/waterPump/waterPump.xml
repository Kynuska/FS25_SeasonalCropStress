<?xml version="1.0" encoding="utf-8"?>
<!--
    waterPump.xml
    Placeable type declaration for the water pump.
    The Lua class (WaterPump) is registered via modDesc.xml <placeableTypes>.
    This file is referenced by modDesc.xml storeItem filename.
-->
<placeable type="waterPump" descVersion="105">

    <storeData>
        <name>$l10n_cs_pump_name</name>
        <image>$data/placeables/brandless/waterTanks/level01/store_waterTankLevel01.dds</image>
        <functions>
            <function>$l10n_cs_pump_function</function>
        </functions>
        <price>12000</price>
        <dailyUpkeep>5</dailyUpkeep>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>PLACEABLE</species>
        <category>waterTanks</category>
        <brush>
            <type>placeable</type>
            <category>buildings</category>
            <tab>tools</tab>
        </brush>
    </storeData>

    <base>
        <filename>placeables/waterPump/waterPump.i3d</filename>
    </base>

    <!-- Custom pump parameters — read by WaterPump:onLoad() via getXMLFloat -->
    <pumpConfig
        waterFlowCapacity="1000"
    />

</placeable>
